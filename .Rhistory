# ---- 1) Read with best header row (tries skip=0..15) ----
read_with_best_header <- function(path, sheet = 1, max_skip = 15) {
best <- NULL
best_score <- -1
best_skip <- 0
for (k in 0:max_skip) {
tmp <- read_excel(path, sheet = sheet, skip = k, .name_repair = "unique")
nms <- tolower(clean_ws(names(tmp)))
score <- sum(str_detect(nms, "taxon|trypanozoon|organism|species|subspecies|strain|isolate|alias|origin|host|year"))
# penalize generic ...1 ...2 headers
score <- score - sum(str_detect(nms, "^\\.\\.\\.[0-9]+$"))
if (score > best_score) {
best <- tmp
best_score <- score
best_skip <- k
}
}
attr(best, "skip_used") <- best_skip
best
}
raw <- read_with_best_header(infile, sheet = insheet, max_skip = 15)
names(raw) <- clean_ws(names(raw))
message("Header skip used: ", attr(raw, "skip_used"))
message("Columns detected: ", paste(names(raw), collapse = " | "))
# ---- 2) Column picker (regex, case-insensitive) ----
pick_col <- function(df, patterns) {
nms <- names(df)
nms_low <- tolower(nms)
hit <- which(str_detect(nms_low, paste0("(", paste(patterns, collapse="|"), ")")))
if (length(hit) == 0) return(NA_character_)
nms[hit[1]]
}
col_taxon <- pick_col(raw, c("^taxon$", "trypanozoon", "organism", "^species$"))
col_code  <- pick_col(raw, c("^code$", "^subspecies$", "subspecies"))
col_id    <- pick_col(raw, c("strain", "isolate", "strain/isolate", "strain\\s*/\\s*isolate"))
col_alias <- pick_col(raw, c("^alias$", "short\\s*name"))
col_geo   <- pick_col(raw, c("geographic", "^origin$", "location"))
col_host  <- pick_col(raw, c("^host$"))
col_year  <- pick_col(raw, c("^year$"))
if (any(is.na(c(col_taxon, col_code, col_id)))) {
stop(
"Could not auto-detect one or more required columns (Taxon/Code/ID).\n",
"Detected:\n",
"  Taxon: ", col_taxon, "\n",
"  Code/Subspecies: ", col_code, "\n",
"  Strain/Isolate ID: ", col_id, "\n\n",
"Fix: set them manually, e.g.\n",
"  col_taxon <- names(raw)[1]\n  col_code <- names(raw)[2]\n  col_id <- names(raw)[3]\n"
)
}
# ---- 3) Build canonical table ----
dat <- raw %>%
transmute(
Taxon = clean_ws(.data[[col_taxon]]),
Code  = clean_ws(.data[[col_code]]),
`Strain / isolate ID` = clean_ws(.data[[col_id]]),
`Alias / short name`  = if (!is.na(col_alias)) clean_alias(.data[[col_alias]]) else NA_character_,
`Geographic origin`   = if (!is.na(col_geo))   clean_ws(.data[[col_geo]])     else NA_character_,
Host                  = if (!is.na(col_host))  clean_ws(.data[[col_host]])    else NA_character_,
Year                  = if (!is.na(col_year))  clean_year(.data[[col_year]])  else NA_integer_
) %>%
mutate(
`Alias / short name` = na_if(`Alias / short name`, ""),
`Geographic origin`  = na_if(`Geographic origin`, ""),
Host = na_if(Host, ""),
Year = ifelse(is.na(Year), NA_integer_, Year)
)
# flag controls
is_control <- str_detect(tolower(dat$Taxon), "non\\-trypanozoon") | dat$Code %in% c("Tco","Tvi","Tth","Tr")
# sort (adjust levels if you prefer)
code_order <- c("Tbb","Tbg","Tbg1","Tbg2","Tbr","Teq","Tev","Tco","Tvi","Tth","Tr")
dat <- dat %>%
mutate(Code = ifelse(Code == "Tbg", "Tbg1", Code),
Code = factor(Code, levels = code_order)) %>%
arrange(is_control, Code, Taxon, `Strain / isolate ID`)
panel <- dat %>% filter(!is_control)
ctrls <- dat %>% filter(is_control)
# ---- 4) Write polished Excel with basic styling ----
wb <- createWorkbook()
addWorksheet(wb, "S7_Strains")
titleStyle  <- createStyle(fontSize=12, textDecoration="bold", fgFill="#7A0000", fontColour="white", halign="left", valign="center", wrapText=TRUE)
headerStyle <- createStyle(fontSize=11, textDecoration="bold", fgFill="#244062", fontColour="white", halign="center", valign="center", border="Bottom", wrapText=TRUE)
sectionStyle<- createStyle(fontSize=11, textDecoration="bold", fgFill="#7A0000", fontColour="white", halign="left", valign="center")
bodyStyle   <- createStyle(fontSize=10, halign="left", valign="top")
caption <- paste0(
"Supplementary Table S7. Trypanozoon strain panel composition (n = ", nrow(panel),
") and non-Trypanozoon controls (n = ", nrow(ctrls), "). ",
"Composition of the analytical inclusivity panel used for strain validation."
)
writeData(wb, "S7_Strains", caption, startRow=1, startCol=1)
mergeCells(wb, "S7_Strains", cols=1:7, rows=1:2)
addStyle(wb, "S7_Strains", titleStyle, rows=1:2, cols=1:7, gridExpand=TRUE)
start_row <- 4
writeData(wb, "S7_Strains", panel, startRow=start_row, startCol=1, withFilter=TRUE)
addStyle(wb, "S7_Strains", headerStyle, rows=start_row, cols=1:7, gridExpand=TRUE)
addStyle(wb, "S7_Strains", bodyStyle, rows=(start_row+1):(start_row+nrow(panel)), cols=1:7, gridExpand=TRUE)
sec_row <- start_row + nrow(panel) + 3
writeData(wb, "S7_Strains", "Non-Trypanozoon controls", startRow=sec_row, startCol=1)
mergeCells(wb, "S7_Strains", cols=1:7, rows=sec_row)
addStyle(wb, "S7_Strains", sectionStyle, rows=sec_row, cols=1:7, gridExpand=TRUE)
writeData(wb, "S7_Strains", ctrls, startRow=sec_row+1, startCol=1)
addStyle(wb, "S7_Strains", headerStyle, rows=sec_row+1, cols=1:7, gridExpand=TRUE)
addStyle(wb, "S7_Strains", bodyStyle, rows=(sec_row+2):(sec_row+1+nrow(ctrls)), cols=1:7, gridExpand=TRUE)
setColWidths(wb, "S7_Strains", cols=1, widths=22)
setColWidths(wb, "S7_Strains", cols=2, widths=8)
setColWidths(wb, "S7_Strains", cols=3, widths=30)
setColWidths(wb, "S7_Strains", cols=4, widths=38)
setColWidths(wb, "S7_Strains", cols=5, widths=24)
setColWidths(wb, "S7_Strains", cols=6, widths=12)
setColWidths(wb, "S7_Strains", cols=7, widths=8)
freezePane(wb, "S7_Strains", firstActiveRow=start_row+1, firstActiveCol=1)
saveWorkbook(wb, outfile, overwrite=TRUE)
message("Wrote: ", outfile)
setwd("~/GitHub/biobank-dashboard")
