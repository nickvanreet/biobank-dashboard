raw <- read_excel(infile, sheet = insheet)
# Try to guess common column headers
names(raw) <- str_replace_all(names(raw), "\\s+", " ")
names(raw) <- str_trim(names(raw))
# Map columns flexibly
col_taxon <- intersect(names(raw), c("Taxon", "Trypanozoon", "Organism"))[1]
col_code  <- intersect(names(raw), c("Code", "Subspecies"))[1]  # your "Subspecies" is the code (Tbb/Tbg/Tbr/Tev/Teq/Tco...)
col_id    <- intersect(names(raw), c("Strain/Isolate ID", "Strain / isolate ID", "Strain", "Isolate ID"))[1]
col_alias <- intersect(names(raw), c("Alias", "Alias / short name", "Short name"))[1]
col_geo   <- intersect(names(raw), c("Geographic origin", "Origin", "Location"))[1]
col_host  <- intersect(names(raw), c("Host"))[1]
col_year  <- intersect(names(raw), c("Year"))[1]
stopifnot(!is.na(col_taxon), !is.na(col_code), !is.na(col_id))
suppressPackageStartupMessages({
library(readxl)
library(dplyr)
library(stringr)
library(openxlsx)
})
infile  <- "Supplementary_Table_S7_raw.xlsx"
insheet <- 1
outfile <- "Supplementary_Table_S7_polished.xlsx"
clean_ws <- function(x) str_trim(str_replace_all(as.character(x), "\\s+", " "))
clean_alias <- function(x) str_replace_all(clean_ws(x), "\\s*\\|\\s*", " | ")
clean_year <- function(x) {
x <- clean_ws(x)
x[x %in% c("", "X", "x", "NA", "N/A")] <- NA
suppressWarnings(as.integer(x))
}
# ---- 1) Read with best header row (tries skip=0..15) ----
read_with_best_header <- function(path, sheet = 1, max_skip = 15) {
best <- NULL
best_score <- -1
best_skip <- 0
for (k in 0:max_skip) {
tmp <- read_excel(path, sheet = sheet, skip = k, .name_repair = "unique")
nms <- tolower(clean_ws(names(tmp)))
score <- sum(str_detect(nms, "taxon|trypanozoon|organism|species|subspecies|strain|isolate|alias|origin|host|year"))
# penalize generic ...1 ...2 headers
score <- score - sum(str_detect(nms, "^\\.\\.\\.[0-9]+$"))
if (score > best_score) {
best <- tmp
best_score <- score
best_skip <- k
}
}
attr(best, "skip_used") <- best_skip
best
}
raw <- read_with_best_header(infile, sheet = insheet, max_skip = 15)
