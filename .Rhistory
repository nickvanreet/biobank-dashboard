# Helpers
# ----------------------------
clean_ws <- function(x) {
x <- as.character(x)
x <- str_replace_all(x, "\\s+", " ")
x <- str_trim(x)
x
}
# unify country abbreviations and separators in Geographic origin
clean_geo <- function(x) {
x <- clean_ws(x)
x <- str_replace_all(x, "\\bRDC\\b", "DRC")
x <- str_replace_all(x, "\\bR\\.D\\.C\\.?\\b", "DRC")
x <- str_replace_all(x, "\\bZAM\\b", "Zambia")
x <- str_replace_all(x, "\\bCI\\b", "Côte d’Ivoire")
x <- str_replace_all(x, "\\bCG\\b", "Republic of the Congo")
x <- str_replace_all(x, "\\bBF\\b", "Burkina Faso")
x <- str_replace_all(x, "\\bCM\\b", "Cameroon")
x <- str_replace_all(x, "\\bET\\b", "Ethiopia")
x <- str_replace_all(x, "\\bKE\\b", "Kenya")
x <- str_replace_all(x, "\\bMW\\b", "Malawi")
x <- str_replace_all(x, "\\bNG\\b", "Nigeria")
x <- str_replace_all(x, "\\bRSA\\b", "South Africa")
x <- str_replace_all(x, "\\bRW\\b", "Rwanda")
x <- str_replace_all(x, "\\bSD\\b", "Sudan")
x <- str_replace_all(x, "\\bTO\\b", "Togo")
x <- str_replace_all(x, "\\bUG\\b", "Uganda")
x <- str_replace_all(x, "\\bVEN\\b", "Venezuela")
x <- str_replace_all(x, "\\bGAM\\b", "The Gambia")
# normalise separators
x <- str_replace_all(x, "\\s*;\\s*", "; ")
x <- str_replace_all(x, "\\s*,\\s*", ", ")
x
}
clean_alias <- function(x) {
x <- clean_ws(x)
x <- str_replace_all(x, "\\s*\\|\\s*", " | ")
x
}
clean_year <- function(x) {
x <- clean_ws(x)
x[x %in% c("", "X", "x", "NA", "N/A")] <- NA
suppressWarnings(as.integer(x))
}
